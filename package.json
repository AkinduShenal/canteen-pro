{
  "name": "canteen-pro",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Canteen Pro client and server",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "start": "concurrently \"cd server && npm start\" \"cd client && npm run dev\"",
    "test:e2e": "npm --prefix client run test:e2e",
    "test:e2e:member1": "npm --prefix client run test:e2e:member1",
    "test:e2e:member2": "npm --prefix client run test:e2e:member2",
    "test:e2e:member3": "npm --prefix client run test:e2e:member3",
    "test:e2e:member4": "npm --prefix client run test:e2e:member4",
    "test:e2e:members": "npm --prefix client run test:e2e:members",
    "test:e2e:ui": "npm --prefix client run test:e2e:ui",
    "test:e2e:headed": "npm --prefix client run test:e2e:headed",
    "test:e2e:install": "npm --prefix client run test:e2e:install"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "react-router-dom": "^7.13.1"
  }
}
